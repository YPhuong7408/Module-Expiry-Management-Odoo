<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model="ir.module.category" id="expiry_group_category_id">
            <field name="name">Expiry Category</field>
            <field name="sequence">1</field>
        </record>

        <record id="group_expiry_user" model="res.groups">
            <field name="name">Employee User</field>
            <field name="category_id" ref="expiry_management.expiry_group_category_id"/>
        </record>

        <record id="group_expiry_manager" model="res.groups">
            <field name="name">Employee Manager</field>
            <field name="implied_ids" eval="[(4, ref('expiry_management.group_expiry_user'))]"/>
            <field name="category_id" ref="expiry_management.expiry_group_category_id"/>
        </record>
    </data>
</odoo>
